{
  "profile": {
    "backend": { "lang": "php", "version": "8.5" },
    "frontend": { "lang": "none", "version": null }
  },
  "codePaths": {
    "backend": ["src"],
    "frontend": []
  },
  "sensitiveGlobs": ["src/**"],
  "quality": {
